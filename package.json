{
  "name": "@company/cyber-sentinel",
  "version": "1.0.0",
  "description": "NestJS security SDK with real-time threat detection, self-healing policies, and CLI scanning",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cyber-sentinel": "dist/scanner/scanner.js",
    "sentinel-scan": "dist/scanner/scanner.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "cyber-sentinel-scan": "ts-node src/scanner/scanner.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "cd": "^0.3.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^9.0.0 || ^10.0.0",
    "@nestjs/core": "^9.0.0 || ^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.0.0",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "nestjs",
    "security",
    "waf",
    "threat-detection",
